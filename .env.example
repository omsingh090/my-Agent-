# Environment Configuration Template
# Copy this to .env and fill in your values
# NEVER commit the actual .env file - it's in .gitignore

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# Agent Configuration
AGENT_NAME=BusinessDecisionAnalyst
AGENT_VERSION=1.0.0
DEBUG=False

# Data Processing
MAX_CHUNK_SIZE=10000
MISSING_VALUE_THRESHOLD=0.5
DUPLICATE_CHECK_ENABLED=True

# Analysis Configuration
MIN_SEGMENT_SIZE=50
TREND_WINDOW_DAYS=30
ANOMALY_SENSITIVITY=0.95

# Priority Engine
IMPACT_WEIGHT=0.4
EFFORT_WEIGHT=0.3
VALUE_WEIGHT=0.3
MIN_PRIORITY_SCORE=6.0

# Output Configuration
CEO_SUMMARY_LENGTH=300
INCLUDE_VISUALIZATIONS=True
OUTPUT_FORMAT=json

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log

# Performance Metrics
ENABLE_PROFILING=False
SAVE_METRICS=True
METRICS_OUTPUT_PATH=metrics/

# Optional: Alternative LLM Providers
# LLM_PROVIDER=anthropic  # Options: openai, anthropic, huggingface
# ANTHROPIC_API_KEY=your_anthropic_key_here
